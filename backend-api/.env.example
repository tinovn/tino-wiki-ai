# ──────────────────────────────────────
# APP
# ──────────────────────────────────────
APP_NAME=tino-wiki-crm
APP_PORT=3000
APP_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ──────────────────────────────────────
# MASTER DATABASE (PostgreSQL)
# ──────────────────────────────────────
MASTER_DATABASE_URL=postgresql://tino_admin:tino_secret_2024@localhost:5432/tino_master

# ──────────────────────────────────────
# REDIS
# ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ──────────────────────────────────────
# QDRANT
# ──────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ──────────────────────────────────────
# JWT
# ──────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ──────────────────────────────────────
# LLM - LOCAL vLLM (Primary)
# ──────────────────────────────────────
LLM_DEFAULT_PROVIDER=vllm
VLLM_BASE_URL=http://180.93.139.245:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct-GPTQ-Int4
VLLM_API_KEY=

# ──────────────────────────────────────
# LLM - OPENAI (Fallback)
# ──────────────────────────────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ──────────────────────────────────────
# LLM - CLAUDE (Optional)
# ──────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ──────────────────────────────────────
# LLM - OLLAMA (Optional)
# ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ──────────────────────────────────────
# EMBEDDING
# ──────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_DIMENSIONS=1536

# ──────────────────────────────────────
# AI PROCESSING
# ──────────────────────────────────────
CHUNK_MIN_TOKENS=300
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=50
MAX_SEARCH_RESULTS=10
