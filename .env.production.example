# ===========================================
# Tino Wiki AI - Production Environment
# ===========================================
# Copy this file to .env and update values
# cp .env.production.example .env
# ===========================================

# ── PostgreSQL ────────────────────────────
POSTGRES_USER=tino_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=tino_master

# ── Redis ─────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT (REQUIRED - generate with: openssl rand -base64 64) ──
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── CORS (supports *.ai.tino.vn subdomains) ──
CORS_ORIGINS=https://ai.tino.vn,https://*.ai.tino.vn

# ── vLLM ──────────────────────────────────
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct-GPTQ-Int4
VLLM_API_KEY=
HF_TOKEN=

# ── LLM Provider ─────────────────────────
LLM_DEFAULT_PROVIDER=vllm

# ── OpenAI (fallback) ────────────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic (optional) ─────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Embedding (BGE-M3 local service) ──────
EMBEDDING_PROVIDER=vllm
EMBEDDING_DIMENSIONS=1024
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32

# ── AI Processing ─────────────────────────
CHUNK_MIN_TOKENS=300
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=50
MAX_SEARCH_RESULTS=10

# ── Qdrant ────────────────────────────────
QDRANT_API_KEY=

# ── Monitoring ────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
